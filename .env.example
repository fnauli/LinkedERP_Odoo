# Odoo connection settings — copy to .env and fill in. Never commit .env.
ODOO_URL=https://demo-skr.odoo.com
ODOO_DB=demo-skr
# The Odoo login (usually an email) that the API key was created for
ODOO_USERNAME=you@example.com
# Create under Odoo: Settings > Users & Companies > Users > API Keys
ODOO_API_KEY=your-api-key-here
